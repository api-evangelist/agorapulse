      "type": "integer",
      "description": "Number of lost followers",
      "format": "int64",
      "example": 2
    },
    "followersNetGrowth": {
      "type": "integer",
      "description": "Net follower growth (gained minus lost)",
      "format": "int64",
      "example": 23
    },
    "followersCount": {
      "type": "integer",
      "description": "Number of total followers",
      "format": "int64",
      "example": 3765
